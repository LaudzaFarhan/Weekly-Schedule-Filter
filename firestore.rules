rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // INSTRUCTOR PROFILES COLLECTION
    // ============================================
    match /instructorProfiles/{profileId} {
      // Allowed for public read (REST API instructors query) and authenticated write
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================
    // CRM LEADS COLLECTION
    // ============================================
    match /crmLeads/{leadId} {
      // Allowed for read/write by both webhooks (unauthenticated REST API) and authenticated users
      allow read, write: if true;
    }

    // ============================================
    // TASKS COLLECTION
    // ============================================
    match /tasks/{taskId} {
      // Only authenticated users can access and manage tasks
      allow read, write: if request.auth != null;
    }

    // ============================================
    // ACTIVITY LOGS COLLECTION
    // ============================================
    match /activityLogs/{logId} {
      // Authenticated users can view activity logs, anyone can write/submit logs (needed for webhook logActivityRest)
      allow read: if request.auth != null;
      allow write: if true;
    }

    // ============================================
    // WORKLOAD SNAPSHOTS COLLECTION
    // ============================================
    match /workloadSnapshots/{snapshotId} {
      // Only authenticated users can access and manage workload snapshots
      allow read, write: if request.auth != null;
    }

    // ============================================
    // INTERNAL CLASSES COLLECTION (New Operations)
    // ============================================
    match /internalClasses/{classId} {
      // Read allowed for anyone, write allowed only for authenticated operators
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================
    // INTERNAL STUDENTS COLLECTION (New Operations)
    // ============================================
    match /internalStudents/{studentId} {
      // Read allowed for anyone, write allowed only for authenticated operators
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================
    // INTERNAL INSTRUCTORS COLLECTION (New Operations)
    // ============================================
    match /internalInstructors/{instructorId} {
      // Read allowed for anyone, write allowed only for authenticated operators
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

