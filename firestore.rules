rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // INSTRUCTOR PROFILES COLLECTION
    // ============================================
    match /instructorProfiles/{profileId} {
      // Any authenticated user can read profiles
      allow read: if request.auth != null;
      // Any authenticated user can create/update/delete profiles
      allow write: if request.auth != null;
    }

    // ============================================
    // CATCH-ALL: Allow all (temporary - expires June 2026)
    // ============================================
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 11);
    }
  }
}
